---
import Tag from './Tag.astro';

interface Props {
  slug: string;
  title: string;
  subtitle: string;
  tags: string[];
  heroImage: string;
}
const { slug, title, subtitle, tags, heroImage } = Astro.props;
---

<a class="case-card" href={`/case/${slug}/`}>
  <div class="case-card__body">
    <div class="case-card__text">
      <h3 class="case-card__title">{title}</h3>
      <p class="case-card__subtitle">{subtitle}</p>
    </div>
    {
      tags.length > 0 && (
        <div class="case-card__tags">
          {tags.map((label) => (
            <Tag label={label} />
          ))}
        </div>
      )
    }
  </div>
  <div class="case-card__media">
    <img src={heroImage} alt={title} loading="lazy" decoding="async" />
  </div>
</a>

<style>
  .case-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-card-gap);
    padding: var(--space-card-padding);
    background: var(--color-surface);
    border-radius: var(--radius-card);
    color: inherit;
    text-decoration: none;
    transition: transform var(--motion-normal) var(--motion-ease);
  }

  .case-card:hover {
    transform: translateY(-4px);
  }

  .case-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-card-stack);
    padding: var(--space-card-inset);
  }

  .case-card__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-card-text-gap);
  }

  .case-card__title {
    font-size: var(--text-title-l);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-normal);
  }

  .case-card__subtitle {
    font-size: var(--text-body);
    font-weight: var(--weight-regular);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
  }

  .case-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-tag-gap);
  }

  .case-card__media {
    height: 232px;
    border-radius: var(--radius-media);
    overflow: hidden;
  }

  .case-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (min-width: 1024px) {
    .case-card {
      flex-direction: row;
      align-items: center;
    }

    .case-card__body {
      flex: 1 0 0;
      min-width: 0;
      align-self: stretch;
      justify-content: space-between;
    }

    .case-card__media {
      flex: 1 0 0;
      min-width: 0;
      height: 420px;
    }
  }
</style>
