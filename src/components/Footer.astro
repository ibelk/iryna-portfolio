---
// `accent` matches the Figma design, where the email renders as an accent link.
const links = [
  { label: 'Linkedin', href: 'https://www.linkedin.com/in/iryna-belkova-1368981a0/', external: true, accent: false },
  { label: 'Telegram', href: 'https://t.me/belkovairyna', external: true, accent: false },
  { label: 'iryn.belkova@gmail.com', href: 'mailto:iryn.belkova@gmail.com', external: false, accent: true },
];
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    {
      links.map((link) => (
        <a
          class:list={['site-footer__link', { 'site-footer__link--accent': link.accent }]}
          href={link.href}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener noreferrer' : undefined}
        >
          {link.label}
        </a>
      ))
    }
  </div>
</footer>

<style>
  .site-footer {
    padding-block: var(--space-section-y);
  }

  .site-footer__inner {
    display: flex;
    flex-direction: column;
    gap: var(--size-16);
    font-size: var(--text-body);
  }

  /* Weight and colour follow the Figma design (SemiBold, white), which is the
     source of truth here — the earlier Regular/muted treatment came from an
     older CSS draft and did not match. */
  .site-footer__link {
    color: var(--color-text-primary);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-snug);
    text-decoration: none;
    transition: opacity var(--motion-fast) var(--motion-ease);
    width: fit-content;
  }

  .site-footer__link--accent {
    color: var(--color-footer-link-accent);
  }

  .site-footer__link:hover {
    opacity: 0.8;
  }

  @media (min-width: 1024px) {
    .site-footer__inner {
      flex-direction: row;
      justify-content: center;
      gap: var(--size-32);
    }
  }
</style>
