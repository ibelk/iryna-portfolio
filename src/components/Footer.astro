---
const links = [
  { label: 'Linkedin', href: 'https://www.linkedin.com/in/iryna-belkova-1368981a0/', external: true },
  { label: 'Telegram', href: 'https://t.me/belkovairyna', external: true },
  { label: 'iryn.belkova@gmail.com', href: 'mailto:iryn.belkova@gmail.com', external: false },
];
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    {
      links.map((link) => (
        <a
          class="site-footer__link"
          href={link.href}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener noreferrer' : undefined}
        >
          {link.label}
        </a>
      ))
    }
  </div>
</footer>

<style>
  .site-footer {
    padding-block: var(--space-section-y);
  }

  .site-footer__inner {
    display: flex;
    flex-direction: column;
    gap: var(--size-16);
    font-size: var(--text-body);
    color: var(--color-text-muted);
  }

  .site-footer__link {
    text-decoration: none;
    transition: color var(--motion-fast) var(--motion-ease);
    width: fit-content;
  }

  .site-footer__link:hover {
    color: var(--color-text-primary);
  }

  @media (min-width: 1024px) {
    .site-footer__inner {
      flex-direction: row;
      justify-content: center;
      gap: var(--size-32);
    }
  }
</style>
