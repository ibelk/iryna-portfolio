---
interface Props {
  title: string;
  image: string;
  href?: string;
}
const { title, image, href } = Astro.props;
const Wrapper = href ? 'a' : 'div';
---

<Wrapper class="experiment-card" href={href}>
  <div class="experiment-card__body">
    <h3 class="experiment-card__title">{title}</h3>
  </div>
  <div class="experiment-card__thumb">
    <img src={image} alt="" loading="lazy" decoding="async" />
  </div>
</Wrapper>

<style>
  .experiment-card {
    display: flex;
    align-items: center;
    gap: var(--size-20);
    padding: var(--space-card-padding);
    background: var(--color-surface);
    border-radius: var(--radius-card);
    color: inherit;
    text-decoration: none;
  }

  .experiment-card__body {
    flex: 1 0 0;
    min-width: 0;
    padding: var(--space-card-inset-sm);
  }

  .experiment-card__title {
    font-size: var(--text-title-s);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-normal);
  }

  .experiment-card__thumb {
    flex: none;
    width: 80px;
    height: 80px;
    border-radius: var(--radius-media-sm);
    overflow: hidden;
  }

  .experiment-card__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (min-width: 1024px) {
    .experiment-card__thumb {
      width: 120px;
      height: 120px;
    }
  }
</style>
