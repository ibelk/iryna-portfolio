---
import Tag from './Tag.astro';

interface Props {
  title: string;
  image: string;
  href: string;
  tags: string[];
}
const { title, image, href, tags } = Astro.props;
---

<a class="writing-card" href={href} target="_blank" rel="noopener noreferrer">
  <div class="writing-card__media">
    <img src={image} alt="" loading="lazy" decoding="async" />
  </div>
  <div class="writing-card__body">
    {
      tags.length > 0 && (
        <div class="writing-card__tags">
          {tags.map((label) => (
            <Tag label={label} />
          ))}
        </div>
      )
    }
    <h3 class="writing-card__title">{title}</h3>
  </div>
</a>

<style>
  .writing-card {
    display: flex;
    flex-direction: column;
    gap: var(--size-8);
    padding: var(--space-card-padding);
    background: var(--color-surface);
    border-radius: var(--radius-card);
    color: inherit;
    text-decoration: none;
    transition: transform var(--motion-normal) var(--motion-ease);
  }

  .writing-card:hover {
    transform: translateY(-4px);
  }

  .writing-card__media {
    height: 232px;
    border-radius: var(--radius-media-post);
    overflow: hidden;
  }

  .writing-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .writing-card__body {
    display: flex;
    flex: 1 0 0;
    flex-direction: column;
    gap: var(--space-card-text-gap);
    padding: var(--space-card-inset-md);
  }

  .writing-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-tag-gap);
  }

  .writing-card__title {
    font-size: var(--text-title-s);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-normal);
  }

  @media (min-width: 1024px) {
    .writing-card__media {
      height: 263px;
    }
  }
</style>
