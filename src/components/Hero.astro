---
interface Props {
  headline: string;
  location: string;
}
const { headline, location } = Astro.props;
---

<section class="hero container" data-reveal>
  <h1 class="hero__headline">{headline}</h1>
  <p class="hero__meta">
    <span class="hero__dot" aria-hidden="true"></span>
    {location}
  </p>
</section>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-block-gap-lg);
    padding-block: var(--space-section-y-lg);
  }

  .hero__headline {
    font-size: var(--text-display);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-normal);
  }

  /* The Figma design shows this in pure white, not the muted tone an earlier
     CSS draft used. Design is the source of truth. */
  .hero__meta {
    display: flex;
    align-items: center;
    gap: var(--size-8);
    font-size: var(--text-body);
    font-weight: var(--weight-regular);
    color: var(--color-text-primary);
  }

  .hero__dot {
    flex: none;
    width: var(--size-8);
    height: var(--size-8);
    border-radius: var(--radius-dot);
    background: var(--color-accent);
  }
</style>
