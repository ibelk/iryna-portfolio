---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import CaseCard from '../components/CaseCard.astro';
import ExperimentCard from '../components/ExperimentCard.astro';
import WritingCard from '../components/WritingCard.astro';
import WritingCta from '../components/WritingCta.astro';

const byOrder = (a: { data: { order: number } }, b: { data: { order: number } }) =>
  a.data.order - b.data.order;

const cases = (await getCollection('case-studies')).sort(byOrder);
const experiments = (await getCollection('experiments')).sort(byOrder);
const posts = (await getCollection('posts')).sort(byOrder).slice(0, 2);
---

<BaseLayout title="Iryna Belkova — Product Designer">
  <Header />

  <main>
    <Hero
      headline="Product designer shipping across the full range — from data-heavy enterprise platforms to consumer mobile apps"
      location="Based in Ukraine"
    />

    <section id="work" class="work" aria-label="Selected work">
      {
        cases.map((entry, i) => (
          <div class="container work__item" style={`--stack-index: ${i}`}>
            <CaseCard
              slug={entry.slug}
              title={entry.data.title}
              subtitle={entry.data.subtitle}
              tags={entry.data.tags}
              heroImage={entry.data.heroImage}
            />
          </div>
        ))
      }
    </section>

    <section id="experiments" class="section container" data-reveal>
      <h2 class="section__title">Experiments</h2>
      <div class="grid grid--two">
        {
          experiments.map((entry) => (
            <ExperimentCard title={entry.data.title} image={entry.data.image} href="/experiments" />
          ))
        }
      </div>
    </section>

    <section id="writing" class="section container" data-reveal>
      <h2 class="section__title">Writing</h2>
      <div class="grid grid--three">
        {
          posts.map((entry) => (
            <WritingCard
              title={entry.data.title}
              image={entry.data.image}
              href={entry.data.linkedinUrl}
              tags={entry.data.tags}
            />
          ))
        }
        <WritingCta
          title="More writing"
          body="Notes on testing new AI-native tools and on troubleshooting design problems inside live products."
          linkLabel="View All Work"
          href="/writing"
        />
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .work {
    display: flex;
    flex-direction: column;
    gap: var(--space-section-gap);
    padding-block: var(--space-section-y);
  }

  /* Desktop card stack: each card sticks a little lower than the one before, so
     the next card scrolls up over it and the edge of each stays visible.
     Pure CSS — no scroll listener, nothing to fall out of sync. */
  @media (min-width: 1024px) {
    .work__item {
      position: sticky;
      top: calc(var(--stack-top) + var(--stack-index) * var(--stack-step));
    }

    /* The card recedes as the next one covers it. The scroll island writes the
       card's inline `transform` and `opacity` on every frame, so the motion is
       already smooth — a CSS `transition` here must NOT be added: it would be
       restarted each frame, never settle, and (as a perpetually-running
       animation) sit above the inline styles in the cascade, overriding them.
       This rule only anchors the scale origin to the top of the card. */
    .work__item > :global(*) {
      transform-origin: top center;
    }

    /* Inside the stack, the card's own hover-lift transition must be off: the
       island rewrites `transform` every frame, and `.case-card`'s `transition:
       transform` would restart each time — a never-settling animation that, in
       the cascade, overrides the inline transform. The stack itself is the
       interaction here, so the hover-lift isn't needed. */
    .work__item > :global(.case-card) {
      transition: none;
    }
    .work__item > :global(.case-card:hover) {
      transform: none;
    }
  }

  /* Scroll-driven stacking is motion; opt out with the rest of the animation. */
  @media (prefers-reduced-motion: reduce) {
    .work__item {
      position: static;
    }
  }

  .section {
    display: flex;
    flex-direction: column;
    gap: var(--space-block-gap);
    padding-block: var(--space-section-y);
  }

  .section__title {
    font-size: var(--text-title-l);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-normal);
  }

  .grid {
    display: grid;
    gap: var(--space-grid-gap);
  }

  @media (min-width: 1024px) {
    .grid--two {
      grid-template-columns: repeat(2, 1fr);
    }

    .grid--three {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
