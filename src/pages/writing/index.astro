---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WritingCard from '../../components/WritingCard.astro';

const posts = (await getCollection('posts')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Writing — Iryna Belkova">
  <Header />

  <main>
    <section class="container page-head">
      <h1 class="page-head__title">Writing</h1>
      <p class="page-head__intro">
        Notes on testing new tools and on troubleshooting design problems inside live products.
        Each one links out to the original post.
      </p>
    </section>

    <section class="container grid">
      {
        posts.map((post) => (
          <WritingCard
            title={post.data.title}
            image={post.data.image}
            href={post.data.linkedinUrl}
            tags={post.data.tags}
          />
        ))
      }
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .page-head {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs-static);
    padding-block: var(--space-section-y);
  }

  .page-head__title {
    font-size: var(--text-display);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-normal);
  }

  .page-head__intro {
    max-width: 60ch;
    color: var(--color-text-muted);
  }

  .grid {
    display: grid;
    gap: var(--space-grid-gap);
    padding-block: var(--space-section-y);
  }

  @media (min-width: 1024px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
